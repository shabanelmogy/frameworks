@{
    ViewData["Title"] = "Overview";
}

<style>
.lesson-container { max-width: 900px; margin: 0 auto; padding-bottom: 3rem; }
.lesson-intro { margin-bottom: 2rem; color: #8b949e; font-size: 1.1rem; }
.example-card { background: var(--card-bg, #21262d); border: 1px solid var(--border, #30363d); border-radius: 8px; padding: 1.5rem; margin-bottom: 2rem; }
.example-card h3 { margin-top: 0; color: #e6edf3; }
.explanation { color: #8b949e; line-height: 1.5; }
.demo-box { background: rgba(0,0,0,0.2); border: 1px solid var(--border, #30363d); border-radius: 6px; padding: 1.5rem; margin-top: 1.5rem; }
.menu-list { display: flex; flex-direction: column; gap: 1rem; }
.menu-item { display: flex; flex-direction: column; padding: 1rem; border: 1px solid #30363d; border-radius: 6px; background: rgba(33, 38, 45, 0.5); text-decoration: none; color: inherit; transition: all 0.2s; }
.menu-item:hover { border-color: #58a6ff; background: rgba(88, 166, 255, 0.1); }
.menu-item strong { color: #e6edf3; margin-bottom: 0.5rem; font-size: 1.1rem; }
.menu-item span { color: #8b949e; font-size: 0.9rem; }
</style>

<div class="lesson-container">
  <h2>Welcome to Angular Overview (MVC Port)</h2>
  <p class="lesson-intro">This learning application is designed to help you bridge your knowledge from React/Blazor to modern Angular 18, recreated in ASP.NET Core MVC.</p>

  <div class="example-card">
    <h3>What's in this guide?</h3>
    <p class="explanation">
      Use the sidebar to navigate through the core concepts. Each lesson contains rich explanations, live interactive demos, and code snippets.
    </p>

    <div class="demo-box menu-list">
      <a asp-action="Variables" class="menu-item">
        <strong>📝 Variables & Inputs</strong>
        <span>Learn about Normal Variables, Signals, and Inputs (like Blazor Parameters or React Props).</span>
      </a>

      <a asp-action="Components" class="menu-item">
        <strong>🧩 Components vs Pages</strong>
        <span>Learn the conceptual difference between a Smart Page Component and a Reusable Dumb Component.</span>
      </a>
      
      <a asp-action="Events" class="menu-item">
        <strong>🖱️ Event Listeners</strong>
        <span>Learn how to bind to clicks, keyboard events, mouse events, form inputs, and how to emit custom output events.</span>
      </a>

      <a asp-action="Services" class="menu-item">
        <strong>🌐 Services & HTTP</strong>
        <span>Learn how to fetch data from APIs using HttpClient and Dependency Injection.</span>
      </a>
      
      <a asp-action="Counter" class="menu-item">
        <strong>🔢 Signals (Counter)</strong>
        <span>Learn how to manage state reactively using Signals (the modern equivalent to React's useState).</span>
      </a>
    </div>
  </div>

  <div class="example-card">
    <h3>Core Philosophy</h3>
    <p class="explanation">
      Unlike React which is just a UI library, Angular is a full-fledged framework. It provides built-in solutions for Routing, Forms, HTTP requests, and Dependency Injection right out of the box. 
    </p>
    <p class="explanation">
      In Modern Angular (v14+), you use <strong>Standalone Components</strong>, which means you no longer need complex <code>NgModules</code>. This makes building in Angular feel much closer to React!
    </p>
  </div>
</div>
