@{
    ViewData["Title"] = "Roadmap Hub";
}

<style>
.lesson-container { max-width: 900px; margin: 0 auto; padding-bottom: 3rem; }
.lesson-intro { margin-bottom: 2rem; color: #8b949e; font-size: 1.1rem; }
.progress-container { background: var(--card-bg, #21262d); border: 1px solid var(--border, #30363d); border-radius: 8px; padding: 1.5rem; margin-bottom: 2rem; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
.progress-bar-bg { width: 100%; height: 12px; background: rgba(139, 148, 158, 0.2); border-radius: 6px; overflow: hidden; margin-bottom: 0.5rem; }
.progress-bar-fill { height: 100%; background: linear-gradient(90deg, #58a6ff, #bc8cff); transition: width 0.4s ease-in-out; }
.progress-text { margin: 0; text-align: right; font-size: 0.9rem; color: #c9d1d9; font-weight: bold; }
.roadmap-grid { display: flex; flex-direction: column; gap: 2rem; }
.roadmap-section { background: rgba(33, 38, 45, 0.5); border-left: 4px solid var(--accent, #58a6ff); border-radius: 0 8px 8px 0; padding: 1.5rem; }
.section-title { margin-top: 0; margin-bottom: 1.5rem; color: #e6edf3; font-size: 1.4rem; }
.topics-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem; }
.topic-card { background: var(--card-bg, #21262d); border: 1px solid var(--border, #30363d); border-radius: 8px; padding: 1.25rem; transition: all 0.2s ease; display: flex; flex-direction: column; }
.topic-card:hover { transform: translateY(-2px); border-color: #8b949e; }
.topic-card.completed { border-color: #238636; background: rgba(35, 134, 54, 0.05); }
.topic-header { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem; }
.topic-checkbox { width: 1.2rem; height: 1.2rem; accent-color: #238636; cursor: pointer; }
.topic-title { margin: 0; font-size: 1.1rem; color: #e6edf3; }
.topic-card.completed .topic-title { text-decoration: line-through; color: #8b949e; }
.topic-desc { color: #8b949e; font-size: 0.9rem; margin-bottom: 1rem; flex-grow: 1; }
.topic-link { display: inline-flex; align-items: center; gap: 0.5rem; color: var(--accent, #58a6ff); text-decoration: none; font-weight: bold; font-size: 0.9rem; transition: opacity 0.2s; }
.topic-link:hover { opacity: 0.8; }
.topic-link span { font-size: 1.1rem; }
</style>

<div class="lesson-container" id="app-root">
  <h2>Angular 2026 Roadmap Explorer (MVC Port)</h2>
  <p class="lesson-intro">
    Track your progress through the ultimate 2026 syllabus. Click the links to navigate directly to the interactive lesson for each topic!
  </p>

  <div class="progress-container">
    <div class="progress-bar-bg">
      <div class="progress-bar-fill" id="progress-bar-fill" style="width: 0%"></div>
    </div>
    <p class="progress-text"><span id="completed-count">0</span> of <span id="total-topics">0</span> completed (<span id="progress-percent">0</span>%)</p>
  </div>

  <div class="roadmap-grid" id="roadmap-grid">
    <!-- Rendered by JS -->
  </div>
</div>

@section Scripts {
<script>
    const ROADMAP_DATA = [
        {
            title: "1. Core Fundamentals",
            topics: [
                { id: "overview", title: "Project Structure & Basics", description: "Angular CLI, Project Structure, Bootstrapping", link: "Overview" },
                { id: "variables", title: "Components & Data Binding", description: "Interpolation, Property Binding, Event Binding", link: "Variables" },
                { id: "directives", title: "Directives & Pipes", description: "Built-in Directives (*ngIf, *ngFor), Custom Directives, Pipes", link: "Directives" },
                { id: "components", title: "Component Communication", description: "@@Input, @@Output, Lifecycle Hooks", link: "Components" },
            ]
        },
        {
            title: "2. Intermediate Concepts",
            topics: [
                { id: "forms", title: "Forms & Validation", description: "Template-Driven Forms, Reactive Forms, Validators", link: "Forms" },
                { id: "services", title: "Dependency Injection & Services", description: "Services, Providers, Hierarchical DI", link: "Services" },
                { id: "events", title: "Routing & Navigation", description: "Routes, RouterOutlet, Lazy Loading", link: "Events" },
            ]
        },
        {
            title: "3. Advanced Concepts (New!)",
            topics: [
                { id: "async", title: "RxJS & Asynchronous Patterns", description: "Observables, Subjects, Operators (map, switchMap, debounceTime)", link: "Async" },
                { id: "auth", title: "Authentication & Route Guards", description: "JWT, CanActivate Guards, Interceptors", link: "Auth" },
                { id: "adv-signals", title: "Advanced Signals", description: "computed(), effect(), linkedSignal(), resource()", link: "AdvancedSignals" },
                { id: "state", title: "State Management", description: "Global State, Signal Store, NgRx basics", link: "State" },
            ]
        }
    ];

    let completedTopics = {};
    const totalTopics = ROADMAP_DATA.reduce((acc, section) => acc + section.topics.length, 0);

    function init() {
        const saved = localStorage.getItem('angular_roadmap_progress');
        if (saved) {
            completedTopics = JSON.parse(saved);
        }
        document.getElementById('total-topics').innerText = totalTopics;
        render();
    }

    function toggleTopic(id) {
        completedTopics[id] = !completedTopics[id];
        localStorage.setItem('angular_roadmap_progress', JSON.stringify(completedTopics));
        render();
    }

    function render() {
        const completedCount = Object.values(completedTopics).filter(Boolean).length;
        const progressPercent = Math.round((completedCount / totalTopics) * 100);

        document.getElementById('completed-count').innerText = completedCount;
        document.getElementById('progress-percent').innerText = progressPercent;
        document.getElementById('progress-bar-fill').style.width = progressPercent + '%';

        const grid = document.getElementById('roadmap-grid');
        grid.innerHTML = '';

        ROADMAP_DATA.forEach(section => {
            const sectionDiv = document.createElement('div');
            sectionDiv.className = 'roadmap-section';
            
            const title = document.createElement('h3');
            title.className = 'section-title';
            title.innerText = section.title;
            sectionDiv.appendChild(title);

            const topicsList = document.createElement('div');
            topicsList.className = 'topics-list';

            section.topics.forEach(topic => {
                const isCompleted = completedTopics[topic.id];
                const card = document.createElement('div');
                card.className = `topic-card ${isCompleted ? 'completed' : ''}`;
                
                let linkHtml = topic.link ? `<a href="/Lessons/${topic.link}" class="topic-link">Go to Lesson <span>→</span></a>` : '';

                card.innerHTML = `
                    <div class="topic-header">
                        <input type="checkbox" class="topic-checkbox" ${isCompleted ? 'checked' : ''} onchange="toggleTopic('${topic.id}')" />
                        <h4 class="topic-title">${topic.title}</h4>
                    </div>
                    <p class="topic-desc">${topic.description}</p>
                    ${linkHtml}
                `;
                topicsList.appendChild(card);
            });

            sectionDiv.appendChild(topicsList);
            grid.appendChild(sectionDiv);
        });
    }

    init();
</script>
}
