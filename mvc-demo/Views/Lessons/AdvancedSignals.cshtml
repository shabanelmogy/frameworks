@{
    ViewData["Title"] = "Advanced Signals";
}

<style>
.lesson-container { max-width: 900px; margin: 0 auto; padding-bottom: 3rem; }
.lesson-intro { margin-bottom: 2rem; color: #8b949e; font-size: 1.1rem; }
.example-card { background: var(--card-bg, #21262d); border: 1px solid var(--border, #30363d); border-radius: 8px; padding: 1.5rem; margin-bottom: 2rem; }
</style>

<div class="lesson-container">
  <h2>Advanced Signals</h2>
  <p class="lesson-intro">Angular Signals support advanced reactivity primitives like <code>computed()</code>, <code>effect()</code>, and <code>linkedSignal()</code>.</p>

  <div class="example-card">
    <p style="color: #e6edf3;">These are advanced client-side reactivity concepts. In a server-rendered MVC app, these concepts aren't directly applicable unless you are using a client-side framework (like Alpine.js, Vue, or React) inside your Razor views.</p>
  </div>
</div>
