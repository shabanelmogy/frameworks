@{
    ViewData["Title"] = "State Management";
}

<style>
.lesson-container { max-width: 900px; margin: 0 auto; padding-bottom: 3rem; }
.lesson-intro { margin-bottom: 2rem; color: #8b949e; font-size: 1.1rem; }
.example-card { background: var(--card-bg, #21262d); border: 1px solid var(--border, #30363d); border-radius: 8px; padding: 1.5rem; margin-bottom: 2rem; }
</style>

<div class="lesson-container">
  <h2>State Management</h2>
  <p class="lesson-intro">Angular uses services or libraries like NgRx to manage complex application state.</p>

  <div class="example-card">
    <p style="color: #e6edf3;">In ASP.NET Core MVC, state is typically managed across requests using Sessions, TempData, databases, or cookies, while page-specific state is passed via ViewModels.</p>
  </div>
</div>
