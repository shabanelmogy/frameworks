@{
    ViewData["Title"] = "Counter";
}

<style>
.counter-card { background: var(--card-bg, #21262d); border: 1px solid var(--border, #30363d); border-radius: 8px; padding: 2rem; text-align: center; max-width: 400px; margin: 2rem auto; }
.display { font-size: 1.5rem; margin-bottom: 2rem; background: #0d1117; padding: 1rem; border-radius: 6px; }
.count-text { margin: 0; color: #e6edf3; }
.actions { display: flex; justify-content: center; gap: 1rem; margin-bottom: 2rem; }
.actions button { background: #238636; border: 1px solid rgba(240,246,252,0.1); color: #fff; padding: 0.5rem 1rem; border-radius: 6px; cursor: pointer; font-weight: bold; }
.actions button:hover { background: #2ea043; }
.actions button:nth-child(2) { background: #30363d; }
.actions button:nth-child(2):hover { background: #8b949e; }
.info { color: #58a6ff; }
.warning { color: #d29922; }
</style>

<div class="counter-card">
  <h2>Counter Example (Vanilla JS State)</h2>

  <div class="display">
    <p class="count-text">Current Count: <strong id="count-display">0</strong></p>
  </div>

  <div class="actions">
    <button onclick="updateCount(-1)">- Decrement</button>
    <button onclick="setCount(0)">Reset</button>
    <button onclick="updateCount(1)">+ Increment</button>
  </div>

  <div class="status" id="status-display">
    <p class="info">The counter is at zero.</p>
  </div>
</div>

@section Scripts {
<script>
    let count = 0;

    function updateCount(delta) {
        setCount(count + delta);
    }

    function setCount(newCount) {
        count = newCount;
        document.getElementById('count-display').innerText = count;
        
        let statusHtml = '';
        if (count === 0) {
            statusHtml = '<p class="info">The counter is at zero.</p>';
        } else if (count > 10) {
            statusHtml = '<p class="warning">Wow, that\'s a high number!</p>';
        } else {
            const isEven = count % 2 === 0;
            statusHtml = `<p class="info">The number is ${isEven ? 'Even' : 'Odd'}.</p>`;
        }
        document.getElementById('status-display').innerHTML = statusHtml;
    }
</script>
}
