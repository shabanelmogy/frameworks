@{
    ViewData["Title"] = "Authentication";
}

<style>
.lesson-container { max-width: 900px; margin: 0 auto; padding-bottom: 3rem; }
.lesson-intro { margin-bottom: 2rem; color: #8b949e; font-size: 1.1rem; }
.example-card { background: var(--card-bg, #21262d); border: 1px solid var(--border, #30363d); border-radius: 8px; padding: 1.5rem; margin-bottom: 2rem; }
</style>

<div class="lesson-container">
  <h2>Authentication & Route Guards</h2>
  <p class="lesson-intro">In Angular, authentication is managed using Route Guards (e.g., CanActivate) and Interceptors to append JWT tokens.</p>

  <div class="example-card">
    <p style="color: #e6edf3;">In ASP.NET Core MVC, authentication is handled natively using Cookie Authentication or Identity middleware, and routes are protected using the <code>[Authorize]</code> attribute on Controllers or Actions.</p>
  </div>
</div>
