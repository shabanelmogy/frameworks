@page "/directives"

<div class="lesson-container">
    <h2>Directives, Bindings & Pipes</h2>
    <p class="lesson-intro">
        Learn how Angular's template features (Directives, Property/Class/Style Bindings, and Pipes) map to Blazor's native Razor syntax and C# equivalents.
    </p>

    <!-- 1. DIRECTIVES SECTION -->
    <div class="example-card">
        <h3>1. Directives (Structural & Attribute)</h3>
        <p class="explanation">
            <strong>Angular:</strong> Uses built-in directives like <code>&#64;if</code> / <code>*ngIf</code> for conditional rendering, <code>&#64;for</code> / <code>*ngFor</code> for lists, and custom attributes to add behavior.<br />
            <strong>Blazor:</strong> Uses standard C# control flow statements (<code>@@if</code>, <code>@@foreach</code>) directly inside the markup. Behavior directives are handled using events like <code>@@onmouseenter</code> or custom components.
        </p>

        <div class="demo-box" style="display: flex; flex-direction: column; gap: 15px;">
            <!-- Conditional Rendering (@if vs @@if) -->
            <div>
                <button class="btn-sm" @onclick="() => IsVisible = !IsVisible">
                    Toggle Visibility (@@if)
                </button>
                @if (IsVisible)
                {
                    <p style="margin-top: 5px; color: #58a6ff;">✨ Now you see me! (Blazor control flow: <code>@@if (IsVisible)</code>)</p>
                }
                else
                {
                    <p style="margin-top: 5px; color: #8b949e;">💨 Elements removed from DOM.</p>
                }
            </div>

            <hr style="border-color: var(--border); margin: 10px 0;" />

            <!-- List Rendering (@for vs @@foreach) -->
            <div>
                <p style="font-weight: bold;">List Rendering (@@foreach):</p>
                <form @onsubmit="AddItem" @onsubmit:preventDefault style="display: flex; gap: 10px; margin: 5px 0;">
                    <input
                        type="text"
                        class="input-field"
                        style="margin: 0;"
                        placeholder="Add fruit..."
                        @bind="NewItem"
                    />
                    <button type="submit" class="btn" style="margin: 0;">Add</button>
                </form>
                <ul>
                    @foreach (var item in Items)
                    {
                        <li style="color: #e6edf3;">@item</li>
                    }
                </ul>
            </div>

            <hr style="border-color: var(--border); margin: 10px 0;" />

            <!-- Custom Attribute Directive Equivalent -->
            <div>
                <p style="font-weight: bold;">Custom Attribute Directive Equivalent (Highlight on Hover):</p>
                <div
                    @onmouseenter='() => Highlight("#ffd33d", "#000000")'
                    @onmouseleave='() => Highlight("#30363d", "#ffffff")'
                    style="padding: 10px; border-radius: 4px; text-align: center; cursor: pointer; transition: all 0.3s ease; background-color: @HoverBgColor; color: @HoverTextColor;"
                >
                    Hover over me to highlight
                </div>
            </div>
        </div>
    </div>

    <!-- 2. BINDINGS SECTION -->
    <div class="example-card">
        <h3>2. Property, Class & Style Bindings</h3>
        <p class="explanation">
            <strong>Angular:</strong> Binds properties via brackets <code>[disabled]="isDisabled"</code>, class/style names via <code>[class.active]="isActive"</code> or <code>[style.background-color]="color"</code>, and two-way bindings via <code>[(ngModel)]</code>.<br />
            <strong>Blazor:</strong> Binds classes using standard C# string interpolation: <code>class="btn @@(IsActive ? \"active-btn\" : \"\")"</code>. Binds styles using style attribute interpolation and two-way bindings via <code>@@bind</code>.
        </p>

        <div class="demo-box" style="display: flex; flex-direction: column; gap: 15px;">
            <!-- Class and Style Bindings -->
            <div>
                <button
                    class="btn @(IsActive ? "active-btn" : "")"
                    style="background-color: @(IsActive ? "#238636" : "#21262d"); border: 1px solid var(--border); margin-right: 10px;"
                    @onclick="() => IsActive = !IsActive"
                >
                    Toggle Class: @(IsActive ? "Active" : "Inactive")
                </button>

                <span class="badge" style="background-color: @BgColor;">
                    Dynamic Style Color
                </span>
                <input
                    type="color"
                    @bind="BgColor"
                    style="vertical-align: middle; margin-left: 10px; cursor: pointer;"
                />
            </div>

            <hr style="border-color: var(--border); margin: 10px 0;" />

            <!-- Two-Way Binding -->
            <div>
                <p style="font-weight: bold;">Two-Way Binding (<code>@@bind</code>):</p>
                <input
                    type="text"
                    class="input-field"
                    @bind="TextInput"
                    @bind:event="oninput"
                />
                <p style="font-size: 0.9em; color: #8b949e;">
                    Value in component state: <strong>@TextInput</strong>
                </p>
            </div>
        </div>
    </div>

    <!-- 3. PIPES/PIPELINES SECTION -->
    <div class="example-card">
        <h3>3. Pipes (Pipelines / Formatters)</h3>
        <p class="explanation">
            <strong>Angular:</strong> Uses the pipe operator <code>|</code> in template expressions to format data: <code>{{ '{{' }} value | uppercase {{ '}}' }}</code>.<br />
            <strong>Blazor:</strong> Uses standard C# expressions, formatting methods, or helper utilities directly inside Razor: <code>@@value.ToUpper()</code> or <code>@@price.ToString(\"C\")</code>.
        </p>

        <div class="demo-box" style="display: flex; flex-direction: column; gap: 10px;">
            <div>
                <p><strong>Input Text:</strong></p>
                <input
                    type="text"
                    class="input-field"
                    @bind="RawText"
                    @bind:event="oninput"
                />
            </div>
            <div>
                <p>Title Case Pipe (Blazor: C# helper):</p>
                <span class="badge">@ToTitleCase(RawText)</span>
            </div>
            <div>
                <p>Currency Pipe (Blazor: <code>.ToString("C")</code>):</p>
                <span class="badge">@Price.ToString("C", new System.Globalization.CultureInfo("en-US"))</span>
            </div>
            <div>
                <p>Date Pipe (Blazor: <code>.ToString("D")</code>):</p>
                <span class="badge">@CurrentDate.ToString("D")</span>
            </div>
        </div>
    </div>
</div>

@code {
    // Structural Directives
    private bool IsVisible = true;
    private List<string> Items = new() { "Apple", "Banana", "Cherry" };
    private string NewItem = "";

    // Highlight on Hover Equivalent
    private string HoverBgColor = "#30363d";
    private string HoverTextColor = "#ffffff";

    private void Highlight(string bgColor, string textColor)
    {
        HoverBgColor = bgColor;
        HoverTextColor = textColor;
    }

    private void AddItem()
    {
        if (!string.IsNullOrWhiteSpace(NewItem))
        {
            Items.Add(NewItem.Trim());
            NewItem = "";
        }
    }

    // Property, Class & Style Bindings
    private bool IsActive = false;
    private string BgColor = "#21262d";
    private string TextInput = "Type here...";

    // Pipes / Formatters
    private string RawText = "blazor is awesome";
    private decimal Price = 12345.67m;
    private DateTime CurrentDate = DateTime.Now;

    private string ToTitleCase(string text)
    {
        if (string.IsNullOrWhiteSpace(text)) return "";
        return System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(text.ToLower());
    }
}
